<?xml version="1.0" encoding="UTF-8"?>
<lint>
    <!--
      The UniFFI-generated bindings (src/main/java/uniffi/, a build output regenerated by
      scripts/build-android-lib.sh) reference java.lang.ref.Cleaner, which is API 33 while our
      minSdk is 26. This is safe: UniFFI picks the implementation at runtime via
      Class.forName("java.lang.ref.Cleaner") and falls back to UniffiJnaCleaner on older
      devices — lint's static analysis just can't see through the reflection guard.

      Scoped to that generated path on purpose. NewApi stays enforced everywhere else, because
      minSdk 26 means real API-level mistakes in our own code would crash on Android 8.
    -->
    <issue id="NewApi">
        <ignore regexp="src/main/java/uniffi/" />
    </issue>
</lint>
